build_settings:
  build_image: dockerfile
  dockerfile_path: Dockerfile
  container_port: 8000
  environment_variables:
    - name: DATABASE_URL
      from_database:
        name: db
        property: private_connection_url
{%- if task_runner == "celery" and celery_broker == "redis" %}
    - name: CELERY_BROKER_URL
      from_database:
        name: cache
        property: connection_url
{%- elif task_runner == "celery" and celery_broker == "rabbitmq" %}
    - name: CELERY_BROKER_URL
      from_database:
        name: broker
        property: connection_url
{%- elif task_runner == "huey" %}
    - name: REDIS_URL
      from_database:
        name: cache
        property: connection_url
{%- endif %}
{%- if media_storage == "s3_compatible" %}
    - name: AWS_ACCESS_KEY_ID
      source: manual
    - name: AWS_SECRET_ACCESS_KEY
      source: manual
    - name: AWS_STORAGE_BUCKET_NAME
      source: manual
    - name: AWS_S3_ENDPOINT_URL
      source: manual
{%- endif %}
{%- if email_backend != "console" %}
    - name: EMAIL_HOST
      source: manual
    - name: EMAIL_PORT
      source: manual
    - name: EMAIL_HOST_USER
      source: manual
    - name: EMAIL_HOST_PASSWORD
      source: manual
{%- endif %}
{%- if use_sentry %}
    - name: SENTRY_DSN
      source: manual
{%- endif %}
    - name: ALLOWED_HOSTS
      from_domains: true
    - name: CSRF_TRUSTED_ORIGINS
      source: manual
    - name: {{ secret_key_var }}
      source: manual
    - name: WEB_CONCURRENCY
      value: "2"

services:
  web:
    command: bash run.sh
  release:
    command: bash release.sh
{%- if task_runner != "none" %}
  worker:
    command: bash worker.sh
{%- endif %}
{%- if task_runner == "celery" and use_beat %}
  beat:
    command: bash celery-beat.sh
{%- endif %}

databases:
  db:
    type: {{ db_type }}
{%- if task_runner == "huey" or (task_runner == "celery" and celery_broker == "redis") %}
  cache:
    type: redis_{{ redis_version }}
{%- endif %}
{%- if task_runner == "celery" and celery_broker == "rabbitmq" %}
  broker:
    type: rabbitmq
{%- endif %}
{%- if media_storage == "volume" %}

volumes:
  media:
    target: /app/media/
    environment_variable: MEDIA_ROOT
{%- endif %}
